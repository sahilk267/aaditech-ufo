# Environment Variables Configuration
# Copy this file to .env and fill in your actual values

# === SECURITY ===
SECRET_KEY=your-secret-key-here-change-in-production
AGENT_API_KEY=your-agent-api-key-here-change-in-production

# === DATABASE ===
DATABASE_URL=sqlite:///toolboxgalaxy.db
# For PostgreSQL: postgresql://user:password@localhost/dbname

# === SERVER ===
FLASK_ENV=development
FLASK_DEBUG=False
HOST=0.0.0.0
PORT=5000

# === LOGGING ===
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# === AGENT ===
AGENT_RUN_INTERVAL=30
MAX_WORKERS=5

# === SECURITY - DO NOT COMMIT .env FILE ===
# Add .env to your .gitignore!
# This file (.env.example) shows the structure.
# Create a .env file locally with your actual secrets.
