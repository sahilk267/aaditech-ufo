# Environment Variables Configuration
# Copy this file to .env and fill in your actual values

# === SECURITY ===
SECRET_KEY=your-secret-key-here-change-in-production
AGENT_API_KEY=your-agent-api-key-here-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-here-change-in-production

# === DATABASE ===
DATABASE_URL=sqlite:///toolboxgalaxy.db
# For PostgreSQL: postgresql://user:password@localhost/dbname

# === SERVER ===
FLASK_ENV=development
FLASK_DEBUG=False
HOST=0.0.0.0
PORT=5000

# === AUTH / SESSION ===
ACCESS_TOKEN_EXPIRES_MINUTES=15
REFRESH_TOKEN_EXPIRES_DAYS=7
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True

# === LOGGING ===
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# === AGENT ===
AGENT_RUN_INTERVAL=30
MAX_WORKERS=5

# === QUEUE / BACKGROUND JOBS ===
QUEUE_BROKER_URL=redis://localhost:6379/0
QUEUE_RESULT_BACKEND=redis://localhost:6379/1

# === OLLAMA / AI ===
OLLAMA_ADAPTER=linux_test_double
OLLAMA_ENDPOINT=http://localhost:11434/api/generate
OLLAMA_DEFAULT_MODEL=llama3.2
OLLAMA_ALLOWED_MODELS=llama3.2
OLLAMA_TIMEOUT_SECONDS=8
OLLAMA_PROMPT_MAX_CHARS=4000
OLLAMA_RESPONSE_MAX_CHARS=4000
OLLAMA_LINUX_TEST_DOUBLE_RESPONSES=

# === ALERTING ===
ALERT_SILENCE_MAX_DURATION_HOURS=72
ALERT_PATTERN_MIN_OCCURRENCES=3
ALERT_PATTERN_WINDOW_SIZE=10

# === AUTOMATION / REMOTE EXECUTION ===
SCHEDULED_JOB_MAX_PER_TENANT=50
SELF_HEALING_DRY_RUN=true
SELF_HEALING_MAX_DEPTH=10
AUTOMATION_EXECUTOR_ADAPTER=linux_test_double
REMOTE_EXEC_ADAPTER=linux_test_double
REMOTE_EXEC_ALLOWED_HOSTS=
REMOTE_EXEC_ALLOWED_COMMANDS=
REMOTE_EXEC_TIMEOUT_SECONDS=10

# === TESTING ===
RATELIMIT_ENABLED=False

# === PHASE 4: PERFORMANCE + CACHE + CDN ===
QUERY_OPTIMIZER_ENABLED=True
QUERY_RECENT_SYSTEMS_LIMIT=10

CACHE_ENABLED=True
CACHE_BACKEND=memory
CACHE_DEFAULT_TTL_SECONDS=60
CACHE_DASHBOARD_TTL_SECONDS=45
CACHE_KEY_PREFIX=aaditech:ufo

CDN_ENABLED=False
CDN_STATIC_BASE_URL=
CDN_STATIC_VERSION=

# === AGENT RELEASE PORTAL ===
AGENT_RELEASES_DIR=agent_releases
AGENT_RELEASE_MAX_MB=256

# === SECURITY - DO NOT COMMIT .env FILE ===
# Add .env to your .gitignore!
# This file (.env.example) shows the structure.
# Create a .env file locally with your actual secrets.
