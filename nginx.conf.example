# Nginx Gateway Configuration for AADITECH UFO Frontend SPA + Flask Backend
# This routes the SPA under /app and API endpoints to Flask on localhost:5000
# 
# Usage:
#   1. Copy this to /etc/nginx/sites-available/aaditech-ufo
#   2. Update server_name to your domain
#   3. Update SSL cert paths
#   4. Symlink to /etc/nginx/sites-enabled/
#   5. Run: sudo nginx -t && sudo systemctl restart nginx

upstream flask_backend {
  server 127.0.0.1:5000;
}

server {
  listen 80;
  server_name aaditech-ufo.local;
  
  # Redirect HTTP to HTTPS (optional, enable for production)
  # return 301 https://$server_name$request_uri;

  # ========== SPA Routes under /app ==========
  location /app/ {
    # Serve static files from the built SPA
    alias /workspaces/aaditech-ufo/frontend/dist/;
    try_files $uri $uri/ /app/index.html;
    expires 30d;
    add_header Cache-Control "public, immutable";
  }

  location = /app {
    rewrite ^$ /app/ permanent;
  }

  # ========== API Routes ==========
  location /api/ {
    proxy_pass http://flask_backend;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Tenant-Slug $http_x_tenant_slug;
    
    # Handle large request bodies if needed
    client_max_body_size 10M;
  }

  # ========== Health Check ==========
  location /health/ {
    proxy_pass http://flask_backend;
    access_log off;
  }

  # ========== Manual Submit Endpoint ==========
  location /manual_submit {
    proxy_pass http://flask_backend;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    
    proxy_request_buffering off;
    proxy_buffering off;
  }

  # ========== Legacy Routes (Optional - Keep for transition period) ==========
  location / {
    proxy_pass http://flask_backend;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
  }

  # ========== Static Assets (Jinja templates img/css/js if needed) ==========
  location /static/ {
    proxy_pass http://flask_backend;
    expires 1h;
    add_header Cache-Control "public";
  }

  # ========== Deny access to sensitive files ==========
  location ~ /\. {
    deny all;
    access_log off;
    log_not_found off;
  }
}

# ========== HTTPS Configuration (Optional - for production) ==========
